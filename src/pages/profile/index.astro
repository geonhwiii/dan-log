---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import { PROFILE, SOCIALS } from "@consts";
import { Rain } from "@components/react/Rain";
import { BottomShadow } from "@components/react/BottomShadow";

const profileCollection = await getCollection("profile");
const bookCollection = await getCollection("book");

profileCollection.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
bookCollection.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<PageLayout title={PROFILE.TITLE} description={PROFILE.DESCRIPTION}>
  <Rain />
  <TopLayout>
    <div class="animate page-heading text-2xl font-bold">
      {"정건휘"}
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate mb-10 space-y-2 text-black/75 dark:text-white/75">
      <p>
        요구사항을 기반으로 예측 가능한 인터페이스와 확장에 유연한 구조로
        설계합니다.
      </p>
      <p>
        React의 선언적 모델과 TypeScript의 정적 타입을 활용해 시스템을 설계하며,
      </p>
      <p>AI 도구를 활용해 가설 검증과 리팩토링 사이클을 단축합니다.</p>
      <p>다양한 직군과의 소통 과정에서 도메인 이해도를 높이고,</p>
      <p>제품에 대한 끊임없는 고민을 바탕으로 더 나은 경험을 만들어갑니다.</p>
    </div>

    <!-- 나의 생각들 -->
    <div class="animate mb-10">
      <p
        class="text-xs uppercase tracking-widest text-black/40 dark:text-white/40 mb-4"
      >
        나의 생각들:
      </p>
      <ul class="space-y-2">
        {
          profileCollection.map((entry) => (
            <li>
              <a
                href={`/profile/${entry.slug}`}
                class="group flex items-center gap-2 text-sm text-black/80 dark:text-white/80 hover:text-black dark:hover:text-white transition-colors"
              >
                <span class="w-1 h-1 rounded-full bg-black/20 dark:bg-white/20 shrink-0 group-hover:bg-black/60 dark:group-hover:bg-white/60 transition-colors" />
                {entry.data.title}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <!-- 좋아하는 책 -->
    <div class="animate mb-10">
      <p
        class="text-xs uppercase tracking-widest text-black/40 dark:text-white/40 mb-4"
      >
        좋아하는 책들:
      </p>
      <ul class="space-y-2">
        {
          bookCollection.map((entry) => (
            <li>
              <a
                href={`/book/${entry.slug}`}
                class="group flex items-center gap-2 text-sm text-black/80 dark:text-white/80 hover:text-black dark:hover:text-white transition-colors"
              >
                <span class="w-1 h-1 rounded-full bg-black/20 dark:bg-white/20 shrink-0 group-hover:bg-black/60 dark:group-hover:bg-white/60 transition-colors" />
                {entry.data.title}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </BottomLayout>
  <BottomShadow />
</PageLayout>
